# SEO On Page Agent — environment variables
#
# Copy this file to `.env` in the project root and fill in the values.
# The agent reads from .env at runtime via `set -a && source .env && set +a`.
# Never commit your real .env. The .gitignore in this repo blocks it by default.

# DataForSEO — used in Phase 1 for live SERP, SERP feature detection, and AI Overview presence
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Firecrawl — used in Phase 2 (audit page scrape) and Phase 3 (competitor scrapes)
FIRECRAWL_API_KEY=

# OpenAI — used in Phase 6 (LLM citation recon) and Phase 8 (topical research)
# Models used: gpt-4o-search-preview (Chat Completions, preferred)
#              gpt-4o + web_search tool (Responses API, fallback)
OPENAI_API_KEY=

# Ahrefs — uses the Ahrefs MCP server, NOT a key in .env.
# Connect the Ahrefs MCP inside your Claude Code environment first.
# The agent discovers Ahrefs tools automatically once the MCP is wired up.
